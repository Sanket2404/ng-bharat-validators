    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "angular",
    "validators",
    "india",
    "bharat",
    "pan",
    "aadhaar",
    "gstin",
    "gst",
