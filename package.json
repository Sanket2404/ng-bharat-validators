  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sanket2404/ng-bharat-validators.git"
  },
  "homepage": "https://github.com/Sanket2404/ng-bharat-validators#readme",
  "bugs": {
    "url": "https://github.com/Sanket2404/ng-bharat-validators/issues"
  },
  "peerDependencies": {
